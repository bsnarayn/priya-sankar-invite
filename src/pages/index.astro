---
import { getEntry } from "astro:content";
import Base from "../layouts/Base.astro";
import Entry from "../components/Entry.astro";
import Hero from "../components/Hero.astro";
import Story from "../components/Story.astro";
import Profiles from "../components/Profiles.astro";
import EventDetails from "../components/EventDetails.astro";
import RSVP from "../components/RSVP.astro";
import PhotoUpload from "../components/PhotoUpload.astro";
import Footer from "../components/Footer.astro";
import PlaneNav from "../components/PlaneNav.astro";
import Petals from "../components/Petals.astro";
import Header from "../components/Header.astro";

const siteEntry = await getEntry("site", "site");
const eventEntry = await getEntry("event", "event");

if (!siteEntry || !eventEntry) throw new Error("Missing content entries");

const site = siteEntry.data;
const event = eventEntry.data;
---

<Base>
	<Petals />
	<Entry />
	<Header />

	<main id="invite" style="opacity:0;transform:translateY(16px);">
		<Hero site={site} event={event} />
		<Story />
		<Profiles />
		<EventDetails event={event} />
		<RSVP site={site} />
		<PhotoUpload site={site} />
		<Footer site={site} />
	</main>
	<PlaneNav />
</Base>

<script>
	// Petals fade in a short while after the entry doors finish opening.
	// Listens for the `invite:opened` event dispatched by Entry.astro —
	// fires on every open, including reopens after the footer close loop.
	const PETAL_FADE_IN_DELAY = 800; // ms

	window.addEventListener("invite:opened", () => {
		setTimeout(() => {
			(window as any).__startPetals?.();
		}, PETAL_FADE_IN_DELAY);
	});
</script>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	const PETAL_FADE_IN_DELAY = 800;

	function registerScrollAnimations() {
		// Kill any leftover triggers from a previous open cycle
		ScrollTrigger.getAll().forEach((t) => t.kill());

		// Section headings & subtext
		gsap.utils
			.toArray<HTMLElement>(".sec-heading, .sec-script, .sec-sub")
			.forEach((el) => {
				gsap.from(el, {
					opacity: 0,
					y: 22,
					duration: 1.1,
					ease: "power2.out",
					scrollTrigger: {
						trigger: el,
						start: "top 88%",
						once: true,
					},
				});
			});

		// Story card
		gsap.from(".story-card", {
			opacity: 0,
			y: 30,
			duration: 1.3,
			ease: "power2.out",
			scrollTrigger: {
				trigger: ".story-card",
				start: "top 85%",
				once: true,
			},
		});

		// Story polaroids — fan in one after another from below, then
		// stay put in their scattered, rotated resting positions.
		gsap.from(".story-polaroid", {
			y: 60,
			opacity: 0,
			scale: 0.85,
			duration: 1,
			ease: "back.out(1.4)",
			stagger: 1.5,
			scrollTrigger: {
				trigger: ".story-polaroids",
				start: "top 80%",
				once: true,
			},
		});

		// Profile cards — staggered
		gsap.from(".profile-card", {
			opacity: 0,
			y: 30,
			duration: 1.2,
			ease: "power2.out",
			stagger: 0.18,
			scrollTrigger: {
				trigger: ".profile-grid",
				start: "top 85%",
				once: true,
			},
		});

		// Event card + venue image + map — cascade
		gsap.from(".event-card", {
			opacity: 0,
			y: 30,
			duration: 1.3,
			ease: "power2.out",
			scrollTrigger: {
				trigger: ".event-card",
				start: "top 85%",
				once: true,
			},
		});

		gsap.from(".venue-cards", {
			opacity: 0,
			y: 24,
			duration: 1.2,
			ease: "power2.out",
			scrollTrigger: {
				trigger: ".venue-cards",
				start: "top 88%",
				once: true,
			},
		});

		// RSVP
		gsap.from(".rsvp-toggle-card", {
			opacity: 0,
			y: 28,
			duration: 1.2,
			ease: "power2.out",
			scrollTrigger: {
				trigger: ".rsvp-toggle-card",
				start: "top 87%",
				once: true,
			},
		});

		// Photo grid
		gsap.from(".photo-grid", {
			opacity: 0,
			y: 28,
			duration: 1.2,
			ease: "power2.out",
			scrollTrigger: {
				trigger: ".photo-grid",
				start: "top 87%",
				once: true,
			},
		});

		// Footer names cascade
		gsap.from(".footer-script, .footer-names, .footer-note", {
			opacity: 0,
			y: 18,
			duration: 1.0,
			ease: "power2.out",
			stagger: 0.12,
			scrollTrigger: {
				trigger: "#footer",
				start: "top 88%",
				once: true,
			},
		});
	}

	window.addEventListener("invite:opened", () => {
		// Petals
		setTimeout(() => {
			(window as any).__startPetals?.();
		}, PETAL_FADE_IN_DELAY);

		// ScrollTrigger — re-registers cleanly on every open cycle
		// Small delay to let GSAP finish the door-open translateY settle
		setTimeout(registerScrollAnimations, 200);
	});
</script>
