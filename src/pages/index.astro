---
import { getEntry } from "astro:content";
import Base from "../layouts/Base.astro";
import Entry from "../components/Entry.astro";
import Hero from "../components/Hero.astro";
import Story from "../components/Story.astro";
import Profiles from "../components/Profiles.astro";
import EventDetails from "../components/EventDetails.astro";
import RSVP from "../components/RSVP.astro";
import PhotoUpload from "../components/PhotoUpload.astro";
import Footer from "../components/Footer.astro";
import PlaneNav from "../components/PlaneNav.astro";
import Petals from "../components/Petals.astro";
import Header from "../components/Header.astro";

const siteEntry = await getEntry("site", "site");
const eventEntry = await getEntry("event", "event");

if (!siteEntry || !eventEntry) throw new Error("Missing content entries");

const site = siteEntry.data;
const event = eventEntry.data;
---

<Base>
	<Petals />
	<Entry />
	<Header />

	<main id="invite" style="opacity:0;transform:translateY(16px);">
		<Hero site={site} event={event} />
		<Story />
		<Profiles />
		<EventDetails event={event} />
		<RSVP site={site} />
		<PhotoUpload site={site} />
		<Footer site={site} />
	</main>
	<PlaneNav />
</Base>

<script>
	// Petals fade in a short while after the entry doors finish opening.
	// Listens for the `invite:opened` event dispatched by Entry.astro —
	// fires on every open, including reopens after the footer close loop.
	const PETAL_FADE_IN_DELAY = 800; // ms

	window.addEventListener("invite:opened", () => {
		setTimeout(() => {
			(window as any).__startPetals?.();
		}, PETAL_FADE_IN_DELAY);
	});
</script>
