---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";

const [siteEntry] = await getCollection("site");
const site = siteEntry.data;
---

<Base title={`Our Camera — ${site.groom_name} & ${site.bride_name}`}>
    <Header showImmediately={true} />

    <div id="cam-page">
        <div class="cam-top">
            <span class="cam-tamil">{site.tamil_names}</span>
            <h1 class="cam-names">
                {site.groom_name}
                <span class="cam-amp">&amp;</span>
                {site.bride_name}
            </h1>
        </div>

        <div>
            <p class="cam-tagline">
                Help us fill our album with moments only you can capture. Every
                photo goes straight into our shared gallery.
            </p>
        </div>

        <div class="cam-bottom">
            <a href="/camera/camera" class="cam-load-btn">Load camera</a>
            <p class="cam-legal">
                Photos are added to our private event album<br />and shared
                after the celebration.
            </p>
        </div>
    </div>
</Base>

<style>
    #cam-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        min-height: 100dvh;
        max-width: 480px;
        margin: 0 auto;
        padding: 140px 32px 48px;
        text-align: center;
        background: radial-gradient(
            ellipse at center,
            #fdf6ee 0%,
            #fffbf6 60%,
            #f5ead8 100%
        );
    }

    .cam-top {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .cam-logo {
        width: 100px;
        height: 100px;
        object-fit: contain;
        margin: 0 auto 24px;
        display: block;
    }

    .cam-tamil {
        font-family: "Catamaran", sans-serif;
        font-weight: 400;
        font-size: 16px;
        letter-spacing: 0.3em;
        color: #146b72;
        opacity: 0.9;
        margin-bottom: 12px;
        display: block;
    }

    .cam-names {
        font-family: "Italiana", serif;
        font-size: clamp(52px, 15vw, 72px);
        line-height: 1;
        color: #3a2e28;
        font-weight: 400;
    }

    .cam-amp {
        font-family: "Great Vibes", cursive;
        color: #146b72;
        font-size: clamp(40px, 12vw, 56px);
        display: block;
        margin: 4px 0;
        font-weight: 400;
    }

    .cam-tagline {
        font-family: "Cormorant Garant", serif;
        font-style: italic;
        font-weight: 300;
        font-size: 17px;
        color: #5c4d43;
        line-height: 1.85;
        max-width: 300px;
    }

    .cam-bottom {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
    }

    .cam-load-btn {
        width: 100%;
        padding: 17px 28px;
        background: #146b72;
        color: #fffbf6;
        border: none;
        border-radius: 8px;
        font-family: "Jost", sans-serif;
        font-size: 12px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        display: block;
        box-sizing: border-box;
        text-align: center;
    }

    .cam-load-btn:hover {
        opacity: 0.9;
    }

    .cam-legal {
        font-family: "Jost", sans-serif;
        font-size: 10px;
        color: #b0998a;
        letter-spacing: 0.05em;
        line-height: 1.7;
    }
</style>
