---
import QR from "./QR.astro";

interface Props {
    site: {
        photo_qr_url?: string;
        immich_base_url?: string;
        immich_share_slug?: string;
    };
}
const { site } = Astro.props;
---

<section
    id="photos"
    data-immich-base={site.immich_base_url ?? ""}
    data-immich-slug={site.immich_share_slug ?? ""}
>
    <div class="inner">
        <h2 class="sec-heading">Share your</h2>
        <span class="sec-script">moments</span>
        <p class="sec-sub">
            Upload from the celebration — straight into our private album. No
            social media.
        </p>

        <div class="photo-grid">
            <!-- Left: drag-and-drop / file picker -->
            <div class="upload-zone" id="upload-zone">
                <svg
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#146B72"
                    stroke-width="1"
                    stroke-linecap="round"
                    style="margin:0 auto 12px;opacity:0.6;display:block;"
                >
                    <path
                        d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"
                    ></path><circle cx="12" cy="13" r="4"></circle>
                </svg>
                <p class="upload-title">Drop your photos here</p>
                <p class="upload-sub">Photos from your phone · Max 5MB each</p>
                <input
                    id="file-input"
                    type="file"
                    accept="image/*"
                    multiple
                    style="display:none;"
                />
                <button
                    id="upload-btn"
                    class="btn-primary"
                    style="margin-top:16px;">Choose photos</button
                >
                <p
                    id="upload-status"
                    style="display:none; margin-top:12px; font-family:'Jost',sans-serif; font-size:12px; color:#7A6A5E;"
                >
                </p>
            </div>

            <!-- Right: QR to /camera page -->
            <QR />
        </div>
    </div>
</section>

<style>
    .upload-zone {
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 100%;
    }
</style>

<script>
    import { uploadFiles } from "@lib/immich-upload";

    const section = document.getElementById("photos") as HTMLElement | null;
    const immichBase =
        section?.dataset.immichBase?.trim().replace(/\/$/, "") ?? "";
    const immichSlug = section?.dataset.immichSlug?.trim() ?? "";

    const uploadBtn = document.getElementById("upload-btn");
    const fileInput = document.getElementById(
        "file-input",
    ) as HTMLInputElement | null;
    const uploadZone = document.getElementById("upload-zone");
    const statusEl = document.getElementById("upload-status");

    uploadBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        fileInput?.click();
    });
    uploadZone?.addEventListener("click", () => fileInput?.click());
    uploadZone?.addEventListener("dragover", (e) => e.preventDefault());
    uploadZone?.addEventListener("drop", (e: DragEvent) => {
        e.preventDefault();
        if (e.dataTransfer?.files) handleFiles(e.dataTransfer.files);
    });
    fileInput?.addEventListener("change", () => {
        if (fileInput?.files) handleFiles(fileInput.files);
    });

    function showStatus(msg: string) {
        if (!statusEl) return;
        statusEl.textContent = msg;
        statusEl.style.display = "block";
    }

    async function handleFiles(files: FileList) {
        const valid = Array.from(files).filter(
            (f) => f.size <= 5 * 1024 * 1024,
        );
        const skipped = files.length - valid.length;

        if (!valid.length) {
            showStatus("Files exceed 5MB limit.");
            return;
        }
        if (!immichBase || !immichSlug) {
            showStatus("Upload isn't set up yet — please scan the QR code.");
            return;
        }

        const config = { base: immichBase, slug: immichSlug, deviceId: "WEB" };

        const uploaded = await uploadFiles(valid, config, (done, total) => {
            showStatus(`Uploading ${done} of ${total}…`);
        });

        if (uploaded === valid.length) {
            let msg = `${uploaded} photo(s) uploaded — thank you!`;
            if (skipped > 0) msg += ` (${skipped} skipped — over 5MB)`;
            showStatus(msg);
        } else if (uploaded > 0) {
            showStatus(
                `${uploaded} of ${valid.length} uploaded — please try the rest again.`,
            );
        } else {
            showStatus("Upload failed — please scan the QR code to try again.");
        }

        if (fileInput) fileInput.value = "";
    }
</script>
