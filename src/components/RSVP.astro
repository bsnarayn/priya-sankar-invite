<section id="rsvp">
    <div class="inner">
        <span class="eyebrow">RSVP</span>
        <h2 class="sec-heading">Will you</h2>
        <span class="sec-script">join us?</span>
        <p class="sec-sub">
            Let us know you're coming. Drop your email and we'll remind you
            before the day.
        </p>

        <div class="rsvp-grid">
            <div class="rsvp-2col">
                <div>
                    <label class="field-label">Your name</label>
                    <input
                        id="rsvp-name"
                        type="text"
                        placeholder="Full name"
                        class="field-input"
                    />
                </div>
                <div>
                    <label class="field-label">Guests</label>
                    <input
                        id="rsvp-guests"
                        type="number"
                        min="1"
                        max="10"
                        placeholder="Including you"
                        class="field-input"
                    />
                </div>
            </div>
            <div>
                <label class="field-label"
                    >Email for reminder <span
                        style="text-transform:none;letter-spacing:normal;opacity:0.6;"
                        >— optional</span
                    ></label
                >
                <input
                    id="rsvp-email"
                    type="email"
                    placeholder="We'll remind you a few days before"
                    class="field-input"
                />
            </div>
            <div class="btn-row">
                <button id="rsvp-submit" class="btn-primary"
                    >Confirm attendance</button
                >
                <button id="cal-btn" class="btn-ghost">
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        ><rect x="3" y="4" width="18" height="18" rx="2"
                        ></rect><path d="M16 2v4M8 2v4M3 10h18M12 14v4M10 16h4"
                        ></path></svg
                    >
                    Add to calendar
                </button>
            </div>
            <p
                id="rsvp-success"
                style="display:none; font-family:'Cormorant Garant',serif; font-style:italic; font-size:14px; color:#C4622D;"
            >
                Thank you — we'll see you there.
            </p>
        </div>
    </div>
</section>

<script>
    const submitBtn = document.getElementById("rsvp-submit");
    const calBtn = document.getElementById("cal-btn");
    const success = document.getElementById("rsvp-success");

    submitBtn?.addEventListener("click", () => {
        const name = (
            document.getElementById("rsvp-name") as HTMLInputElement
        )?.value.trim();
        const guests = (
            document.getElementById("rsvp-guests") as HTMLInputElement
        )?.value;
        const email = (
            document.getElementById("rsvp-email") as HTMLInputElement
        )?.value.trim();
        if (!name) {
            alert("Please enter your name.");
            return;
        }
        console.log("RSVP:", { name, guests, email });
        (submitBtn as HTMLButtonElement).textContent = "Confirmed ✓";
        (submitBtn as HTMLButtonElement).disabled = true;
        if (success) success.style.display = "block";
    });

    calBtn?.addEventListener("click", () => {
        const ics = [
            "BEGIN:VCALENDAR",
            "VERSION:2.0",
            "BEGIN:VEVENT",
            "DTSTART:20251231T180000Z",
            "DTEND:20251231T230000Z",
            "SUMMARY:Sankar & Priya — Reception & Celebration",
            "DESCRIPTION:Some love stories begin with a flight.",
            "LOCATION:To be announced",
            "END:VEVENT",
            "END:VCALENDAR",
        ].join("\r\n");
        const blob = new Blob([ics], { type: "text/calendar" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "sankar-priya.ics";
        a.click();
        URL.revokeObjectURL(url);
    });
</script>
