---
interface Props {
    site: { rsvp_webhook_url?: string };
}
const { site } = Astro.props;
---

<section id="rsvp" data-webhook-url={site.rsvp_webhook_url ?? ""}>
    <div class="inner">
        <span class="eyebrow">RSVP</span>
        <h2 class="sec-heading">Will you</h2>
        <span class="sec-script">join us?</span>
        <p class="sec-sub">
            Let us know you're coming. Drop your email and we'll remind you
            before the day.
        </p>

        <div class="rsvp-grid">
            <div class="rsvp-2col">
                <div>
                    <label class="field-label">Your name</label>
                    <input
                        id="rsvp-name"
                        type="text"
                        placeholder="Full name"
                        class="field-input"
                    />
                </div>
                <div>
                    <label class="field-label">Guests</label>
                    <input
                        id="rsvp-guests"
                        type="number"
                        min="1"
                        max="10"
                        placeholder="Including you"
                        class="field-input"
                    />
                </div>
            </div>
            <div>
                <label class="field-label"
                    >Email for reminder <span
                        style="text-transform:none;letter-spacing:normal;opacity:0.6;"
                        >— optional</span
                    ></label
                >
                <input
                    id="rsvp-email"
                    type="email"
                    placeholder="We'll remind you a few days before"
                    class="field-input"
                />
            </div>
            <div
                style="position:absolute;left:-9999px;top:-9999px;"
                aria-hidden="true"
            >
                <label for="rsvp-website">Leave this field empty</label>
                <input
                    id="rsvp-website"
                    name="website"
                    type="text"
                    tabindex="-1"
                    autocomplete="off"
                />
            </div>
            <div class="btn-row">
                <button id="rsvp-submit" class="btn-primary"
                    >Confirm attendance</button
                >
                <button id="cal-btn" class="btn-ghost">
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        ><rect x="3" y="4" width="18" height="18" rx="2"
                        ></rect><path d="M16 2v4M8 2v4M3 10h18M12 14v4M10 16h4"
                        ></path></svg
                    >
                    Add to calendar
                </button>
            </div>
            <p
                id="rsvp-success"
                style="display:none; font-family:'Cormorant Garant',serif; font-style:italic; font-size:14px; color:#146B72;"
            >
                Thank you — we'll see you there.
            </p>
            <p
                id="rsvp-error"
                style="display:none; font-family:'Jost',sans-serif; font-size:12px; color:#B33E66;"
            >
            </p>
        </div>
    </div>
</section>

<script>
    const section = document.getElementById("rsvp") as HTMLElement | null;
    const webhookUrl = section?.dataset.webhookUrl?.trim();

    const submitBtn = document.getElementById(
        "rsvp-submit",
    ) as HTMLButtonElement | null;
    const calBtn = document.getElementById("cal-btn");
    const success = document.getElementById("rsvp-success");
    const error = document.getElementById("rsvp-error");

    const originalLabel = submitBtn?.textContent ?? "Confirm attendance";

    submitBtn?.addEventListener("click", async () => {
        const name = (
            document.getElementById("rsvp-name") as HTMLInputElement
        )?.value.trim();
        const guestsRaw = (
            document.getElementById("rsvp-guests") as HTMLInputElement
        )?.value.trim();
        const email = (
            document.getElementById("rsvp-email") as HTMLInputElement
        )?.value.trim();

        if (error) error.style.display = "none";

        const honeypot = (
            document.getElementById("rsvp-website") as HTMLInputElement
        )?.value;

        if (honeypot) {
            // Bot filled the hidden field — pretend success, do nothing else
            submitBtn.textContent = "Confirmed ✓";
            submitBtn.disabled = true;
            if (success) success.style.display = "block";
            return;
        }

        if (!name) {
            alert("Please enter your name.");
            return;
        }

        const guests = guestsRaw ? parseInt(guestsRaw, 10) : 1;

        if (!webhookUrl) {
            console.warn("RSVP webhook URL not configured in site.json.");
            if (error) {
                error.textContent =
                    "RSVP submission isn't set up yet — please message the couple directly for now.";
                error.style.display = "block";
            }
            return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = "Sending...";

        try {
            const res = await fetch(webhookUrl, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    name,
                    guests,
                    email,
                    timestamp: new Date().toISOString(),
                }),
            });

            if (!res.ok) throw new Error(`Request failed: ${res.status}`);

            submitBtn.textContent = "Confirmed ✓";
            if (success) success.style.display = "block";
        } catch (err) {
            console.error("RSVP submission failed:", err);
            submitBtn.disabled = false;
            submitBtn.textContent = originalLabel;
            if (error) {
                error.textContent =
                    "Something went wrong sending your RSVP — please try again, or message us directly.";
                error.style.display = "block";
            }
        }
    });

    calBtn?.addEventListener("click", () => {
        const ics = [
            "BEGIN:VCALENDAR",
            "VERSION:2.0",
            "BEGIN:VEVENT",
            "DTSTART:20251231T180000Z",
            "DTEND:20251231T230000Z",
            "SUMMARY:Sankar & Priya — Reception & Celebration",
            "DESCRIPTION:Some love stories begin with a flight.",
            "LOCATION:To be announced",
            "END:VEVENT",
            "END:VCALENDAR",
        ].join("\r\n");
        const blob = new Blob([ics], { type: "text/calendar" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "sankar-priya.ics";
        a.click();
        URL.revokeObjectURL(url);
    });
</script>
