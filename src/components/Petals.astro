---
// Petals — "shower of blessings" ambient animation
// Self-contained: renders its own full-viewport layer and starts
// animating on load. Call (window as any).__stopPetals() to halt.
---

<div
    id="petal-layer"
    style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:52;pointer-events:none;"
    aria-hidden="true"
>
</div>

<script>
    import { gsap } from "gsap";

    const petalLayer = document.getElementById("petal-layer");

    // Soft, warm petal tones — small ovals, varied size/opacity/blur
    const PETAL_COLORS = ["#C9A227", "#D98E5C", "#E8A0A8", "#7D1A6B"];
    const PETAL_COUNT = 14;

    let petalTweens: gsap.core.Tween[] = [];

    function petalSVG(color: string, size: number) {
        // Simple oval petal — slightly elongated, like the reference
        const w = size;
        const h = size * 1.6;
        return `<svg width="${w}" height="${h}" viewBox="0 0 10 16" xmlns="http://www.w3.org/2000/svg" style="display:block;">
            <ellipse cx="5" cy="8" rx="5" ry="8" fill="${color}" />
        </svg>`;
    }

    function spawnPetals() {
        if (!petalLayer) return;
        petalLayer.innerHTML = "";
        petalTweens = [];

        const vw = window.innerWidth;
        const vh = window.innerHeight;

        for (let i = 0; i < PETAL_COUNT; i++) {
            const size = 8 + Math.random() * 10; // 8–18px base width
            const color =
                PETAL_COLORS[Math.floor(Math.random() * PETAL_COLORS.length)];
            const opacity = 0.35 + Math.random() * 0.35; // 0.35–0.7
            const blur = Math.random() > 0.6 ? "1px" : "0px";

            const fallDuration = 16 + Math.random() * 10; // 16–26s
            const sway = 10 + Math.random() * 20; // 10–30px
            const swayDuration = 4 + Math.random() * 3; // 4–7s
            const rotateAmount = 15 + Math.random() * 30; // 15–45°
            const rotateDir = Math.random() > 0.5 ? 1 : -1;

            const el = document.createElement("div");
            el.style.position = "absolute";
            el.style.top = "0";
            el.style.opacity = String(opacity);
            el.style.filter = `blur(${blur})`;
            el.innerHTML = petalSVG(color, size);
            petalLayer.appendChild(el);

            // Base horizontal position (CSS `left`) — only changed on
            // fall-cycle repeat. Sway uses `x` (transform) separately,
            // so the two never collide.
            function setBaseX() {
                el.style.left = `${Math.random() * vw}px`;
            }
            setBaseX();

            gsap.set(el, { y: -size * 2, x: 0, rotation: 0 });

            const fallTween = gsap.to(el, {
                y: vh + size * 2,
                duration: fallDuration,
                repeat: -1,
                ease: "none",
                onRepeat: () => {
                    setBaseX();
                    gsap.set(el, { y: -size * 2 });
                },
            });
            fallTween.progress(Math.random());

            const swayTween = gsap.to(el, {
                x: `+=${sway}`,
                duration: swayDuration,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            swayTween.progress(Math.random());

            const rotateTween = gsap.to(el, {
                rotation: rotateAmount * rotateDir,
                duration: swayDuration * 1.3,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            rotateTween.progress(Math.random());

            petalTweens.push(fallTween, swayTween, rotateTween);
        }
    }

    function stopPetals() {
        petalTweens.forEach((t) => t.kill());
        if (petalLayer) petalLayer.innerHTML = "";
        petalTweens = [];
    }

    (window as any).__startPetals = spawnPetals;
    (window as any).__stopPetals = stopPetals;

    spawnPetals();
</script>
