---
interface Props {
    site: {
        groom_name: string;
        bride_name: string;
        tagline: string;
        hero_pre: string;
        tamil_names: string;
    };
    event: {
        date: string;
        time: string;
        venue: string;
    };
}
const { site, event } = Astro.props;
---

<section id="hero">
    <span class="hero-tamil">{site.tamil_names}</span>
    <p class="hero-pre">{site.hero_pre}</p>
    <h1 class="hero-names">
        {site.groom_name}
        <span class="hero-amp">&amp;</span>
        {site.bride_name}
    </h1>
    <div class="hero-rule"></div>
    <p class="hero-tagline">{site.tagline}</p>
    <p class="hero-date">
        Reception &amp; Celebration &nbsp;·&nbsp; {event.date} &nbsp;·&nbsp; {
            event.venue
        }
    </p>
    <div
        class="scroll-hint"
        style="margin-top:48px; display:flex; flex-direction:column; align-items:center; gap:6px; opacity:0.4;"
    >
        <span
            style="font-family:'Jost',sans-serif; font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:#7A6A5E;"
            >scroll</span
        >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path
                d="M8 3v10M8 13l-4-4M8 13l4-4"
                stroke="#146B72"
                stroke-width="1"
                stroke-linecap="round"></path>
        </svg>
    </div>
</section>
