    <p
        class="tap-prompt"
        style="margin:16px 0 0;
           font-family:var(--font-family-sans);
           font-size:14px;
           letter-spacing:0.3em;
           text-transform:uppercase;
           color:var(--color-text-primary);
           opacity:0.6;
           white-space:nowrap;"
    >
        Tap to Celebrate
    </p>
</div>

<script>
    import { gsap } from "gsap";

    const screen = document.getElementById("entry-screen");
    const monogramWrap = document.getElementById("monogram-wrap");
    const doorL = document.getElementById("door-left");
    const doorR = document.getElementById("door-right");
    const pGroup = document.getElementById("p-group");
    const sGroup = document.getElementById("s-group");
    const tapPrompt = document.querySelector(".tap-prompt");
    const invite = document.getElementById("invite");

    let triggered = false;

    function playWhoosh() {
        try {
            const ctx = new AudioContext();
            const bufferSize = ctx.sampleRate * 0.8;
            const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
            const data = buffer.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) {
                data[i] = (Math.random() * 2 - 1) * (1 - i / bufferSize);
            }
            const source = ctx.createBufferSource();
            source.buffer = buffer;
            const filter = ctx.createBiquadFilter();
            filter.type = "bandpass";
            filter.frequency.value = 800;
            filter.Q.value = 0.8;
            const gain = ctx.createGain();
            gain.gain.setValueAtTime(0.0, ctx.currentTime);
            gain.gain.linearRampToValueAtTime(0.4, ctx.currentTime + 0.05);
            gain.gain.exponentialRampToValueAtTime(
                0.001,
                ctx.currentTime + 0.7,
            );
            source.connect(filter);
            filter.connect(gain);
            gain.connect(ctx.destination);
            source.start();
        } catch (_) {}
    }

    function launch() {
        if (triggered) return;
        triggered = true;
        playWhoosh();

        const tl = gsap.timeline();

        tl.to(tapPrompt, {
            opacity: 0,
            duration: 0.3,
            ease: "power2.in",
        })
            .addLabel("open", "-=0.1")
            .to(
                doorL,
                { x: "-100%", duration: 1.6, ease: "power3.inOut" },
                "open",
            )
            .to(
                doorR,
                { x: "100%", duration: 1.6, ease: "power3.inOut" },
                "open",
            )
            .to(
                pGroup,
                { x: -1500, duration: 1.6, ease: "power3.inOut" },
                "open",
            )
            .to(
                sGroup,
                { x: 1500, duration: 1.6, ease: "power3.inOut" },
                "open",
            )
            .fromTo(
                invite,
                { opacity: 0, y: 16 },
                { opacity: 1, y: 0, duration: 1.3, ease: "power2.out" },
                "open+=0.4",
            )
            .set([screen, monogramWrap], { display: "none" })
            .then(() => {
                document.body.classList.remove("no-scroll");
                (window as any).__stopPetals?.();
                (window as any).__stopBalloons?.();
                (window as any).__stopHearts?.();
            });
    }

    screen?.addEventListener("click", launch);
    screen?.addEventListener("touchend", (e) => {
        e.preventDefault();
        launch();
    });
    document.body.classList.add("no-scroll");

    (window as any).__resetEntry = function () {
        triggered = false;
        document.body.classList.add("no-scroll");
        gsap.set(monogramWrap, { display: "flex" });
        gsap.set(doorL, { x: "0%" });
        gsap.set(doorR, { x: "0%" });
        gsap.set(pGroup, { x: 0 });
        gsap.set(sGroup, { x: 0 });
        gsap.set(tapPrompt, { opacity: 0.4 });
        (window as any).__startPetals?.();
        (window as any).__startBalloons?.();
        (window as any).__startHearts?.();
    };

    (window as any).__resetEntry();
</script>
