---
// Entry screen — split monogram reveal
import Petals from "./Petals.astro";
import Balloons from "./Balloons.astro";
import Hearts from "./Hearts.astro";
---

<Petals />
<Balloons />
<Hearts />

<div
    id="entry-screen"
    style="position:fixed;inset:0;z-index:50;display:flex;cursor:pointer;user-select:none;overflow:hidden;"
    aria-label="Tap to open"
>
    <div id="door-left" style="width:50%;height:100%;background:#e7d8c3;"></div>
    <div id="door-right" style="width:50%;height:100%;background:#F2E8D5;">
    </div>
</div>

