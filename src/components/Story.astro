---
import { getEntry, render, getCollection } from "astro:content";
import sliderImagesData from "../content/story/sliderimages.json";

const story = await getEntry("story", "story");
if (!story) throw new Error("Missing story content");
const { Content } = await render(story);

const [siteEntry] = await getCollection("site");
const site = siteEntry.data;

// sliderimages.json is a plain array of filenames living in
// public/images/story/. site.story_images optionally caps how many
// of those are shown (0 or unset = no cap).
const allFilenames: string[] = Array.isArray(sliderImagesData)
    ? sliderImagesData
    : [];
const cap =
    site.story_images && site.story_images > 0 ? site.story_images : undefined;
const filenames = cap ? allFilenames.slice(0, cap) : allFilenames;
const storyImages = filenames.map((name) => `/images/story/${name}`);
const hasImages = storyImages.length > 0;
---

<section id="story">
    <div class="inner">
        <h2 class="sec-heading">How we got</h2>
        <span class="sec-script">here</span>
        <div class="story-card">
            <div class="story-text">
                <h3 class="story-title">{story.data.title}</h3>
                <div class="story-body">
                    <Content />
                </div>
            </div>
            <div class="story-img">
                {
                    hasImages ? (
                        <div class="story-carousel">
                            <div
                                class="story-carousel-track"
                                style={`--story-set-width:${storyImages.length * 320}px; --story-marquee-duration:${storyImages.length * 8}s;`}
                            >
                                {storyImages.map((src) => (
                                    <div class="story-carousel-slide">
                                        <img src={src} alt="Our story" />
                                    </div>
                                ))}
                                {/* Duplicate set for seamless marquee loop */}
                                {storyImages.map((src) => (
                                    <div
                                        class="story-carousel-slide"
                                        aria-hidden="true"
                                    >
                                        <img src={src} alt="" />
                                    </div>
                                ))}
                            </div>
                        </div>
                    ) : (
                        <>
                            <svg
                                width="32"
                                height="32"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="#C4622D"
                                stroke-width="1"
                                stroke-linecap="round"
                            >
                                <>
                                    <rect
                                        x="3"
                                        y="3"
                                        width="18"
                                        height="18"
                                        rx="2"
                                    />
                                    <circle cx="8.5" cy="8.5" r="1.5" />
                                    <path d="M21 15l-5-5L5 21" />
                                </>
                            </svg>
                            <span>Your photo here</span>
                        </>
                    )
                }
            </div>
        </div>
    </div>
</section>
