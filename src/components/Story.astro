---
import { getEntry, render, getCollection } from "astro:content";

const story = await getEntry("story", "story");
if (!story) throw new Error("Missing story content");
const { Content } = await render(story);

const [siteEntry] = await getCollection("site");
const site = siteEntry.data;

// Auto-discover every image in src/images/story/, regardless of
// extension. import.meta.glob runs at build time (Vite), so it works
// with the Cloudflare adapter — unlike fs.readdirSync, which requires
// Node filesystem access not available in the Workers runtime.
// Each match resolves to a processed, served asset URL (string).
const storyImageModules = import.meta.glob<string>(
    "/src/images/story/*.{jpg,jpeg,png,webp,gif,avif,JPG,JPEG,PNG,WEBP,GIF,AVIF}",
    { eager: true, query: "?url", import: "default" },
);

let allUrls = Object.values(storyImageModules);

// Shuffle (Fisher-Yates) for variety between builds — fine for a
// continuously-looping carousel.
for (let i = allUrls.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [allUrls[i], allUrls[j]] = [allUrls[j], allUrls[i]];
}

// site.story_images optionally caps how many images are shown
// (0 or unset = no cap). The polaroid scatter is hand-tuned for up to
// 5 photos, so it's capped there regardless of site.story_images.
const MAX_POLAROIDS = 5;
const cap =
    site.story_images && site.story_images > 0 ? site.story_images : undefined;
const storyImages = (cap ? allUrls.slice(0, cap) : allUrls).slice(
    0,
    MAX_POLAROIDS,
);
const hasImages = storyImages.length > 0;
---

<section id="story">
    <div class="inner">
        <h2 class="sec-heading">How we got</h2>
        <span class="sec-script">here</span>
        <div class="story-card">
            <div class="story-text">
                <h3 class="story-title">{story.data.title}</h3>
                <div class="story-body">
                    <Content />
                </div>
            </div>
            <div class="story-img">
                {
                    hasImages ? (
                        <div class="story-polaroids">
                            {storyImages.map((src, i) => (
                                <div class={`story-polaroid story-polaroid--${i}`}>
                                    <img
                                        src={src}
                                        alt="Our story"
                                        loading={i === 0 ? "eager" : "lazy"}
                                    />
                                </div>
                            ))}
                        </div>
                    ) : (
                        <>
                            <svg
                                width="32"
                                height="32"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="#C4622D"
                                stroke-width="1"
                                stroke-linecap="round"
                            >
                                <>
                                    <rect
                                        x="3"
                                        y="3"
                                        width="18"
                                        height="18"
                                        rx="2"
                                    />
                                    <circle cx="8.5" cy="8.5" r="1.5" />
                                    <path d="M21 15l-5-5L5 21" />
                                </>
                            </svg>
                            <span>Your photo here</span>
                        </>
                    )
                }
            </div>
        </div>
    </div>
</section>
