---
import { getCollection } from "astro:content";
import HeartsSection from "./HeartsSection.astro";

const couple = await getCollection("couple");
const groom = couple.find((p) => p.id === "groom");
const bride = couple.find((p) => p.id === "bride");
if (!groom || !bride) throw new Error("Missing couple content");
---

<section id="people">
  <HeartsSection />
  <div class="inner">
    <h2 class="sec-heading">Behind the</h2>
    <span class="sec-script">celebration</span>

    <div class="profile-grid">
      {
        [groom, bride].map((person) => {
          const photoSrc = person.data.photo
            ? `/images/profiles/${person.data.photo}`
            : undefined;
          return (
            <div class={`profile-card profile-card--${person.id}`}>
              <div class="profile-photo">
                {photoSrc ? (
                  <img src={photoSrc} alt={person.data.name} loading="lazy" />
                ) : (
                  <div class="profile-photo--placeholder">
                    <svg
                      width="32"
                      height="32"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="#C4622D"
                      stroke-width="1"
                      stroke-linecap="round"
                    >
                      <circle cx="12" cy="8" r="4" />
                      <path d="M4 20c0-4 4-6 8-6s8 2 8 6" />
                    </svg>
                    <span>Your photo here</span>
                  </div>
                )}
              </div>
              <div class="profile-content">
                <p class="profile-initial">{person.data.name}</p>
                <p class="profile-role">{person.data.role}</p>
                <p class="profile-bio">"{person.data.bio}"</p>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  // Light up the profile card accent strip (left edge + top edge of
  // photo area) when the card enters the viewport. The CSS transition
  // on ::before draws the border left→top via clip-path.
  const cards = document.querySelectorAll<HTMLElement>(
    ".profile-card--groom, .profile-card--bride",
  );
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("strip-lit");
          observer.unobserve(entry.target); // fire once only
        }
      });
    },
    { threshold: 0.3 },
  );
  cards.forEach((card) => observer.observe(card));
</script>
