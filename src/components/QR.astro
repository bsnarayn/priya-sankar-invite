---
// QR card — links to /camera (the disposable camera page)
---

<div class="qr-card">
    <p class="qr-label">Scan to use our camera</p>
    <div class="qr-box">
        <img id="camera-qr" alt="Scan to open camera" />
    </div>
    <a id="camera-link" href="/camera" class="qr-link">Open on this device →</a>
</div>

<style>
    .qr-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
    }

    .qr-box {
        width: 80%;
        max-width: 280px;
        aspect-ratio: 1;
        background: #ede4d8;
        border-radius: 8px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .qr-box img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 8px;
    }

    .qr-link {
        display: block;
        margin-top: 14px;
        font-family: "Jost", sans-serif;
        font-size: 12px;
        color: #157A78;
        text-align: center;
        text-decoration: none;
    }

    .qr-link:hover {
        text-decoration: underline;
    }
</style>

<script>
    const cameraUrl = `${window.location.origin}/camera`;
    const qrImg = document.getElementById(
        "camera-qr",
    ) as HTMLImageElement | null;
    if (qrImg) {
        qrImg.src = `https://api.qrserver.com/v1/create-qr-code/?size=400x400&data=${encodeURIComponent(cameraUrl)}`;
    }
</script>
