---
interface Props {
    event: {
        date: string;
        time: string;
        venue: string;
        address: string;
        maps_url?: string;
        dress: string;
        venue_image?: string;
        start_datetime?: string | null;
        end_datetime?: string | null;
    };
}
const { event } = Astro.props;

const venueImageSrc = event.venue_image
    ? `/images/venue/${event.venue_image}`
    : undefined;

const calData = {
    startDatetime: event.start_datetime ?? null,
    endDatetime: event.end_datetime ?? null,
    venue: event.venue,
    address: event.address,
    mapsUrl: event.maps_url,
};
---

<section id="event">
    <div class="inner">
        <h2 class="sec-heading">Reception &amp;</h2>
        <span class="sec-script">Celebration</span>

        <!-- Event details card — date/time/venue/dress/address/button -->
        <div class="event-card">
            <div class="event-list">
                <div class="event-row">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#157A78"
                        stroke-width="1.2"
                        stroke-linecap="round"
                    >
                        <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                        <path d="M16 2v4M8 2v4M3 10h18"></path>
                    </svg>
                    <div>
                        <p class="event-lbl">Date</p>
                        <p class="event-val">{event.date}</p>
                    </div>
                </div>
                <div class="event-row">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#157A78"
                        stroke-width="1.2"
                        stroke-linecap="round"
                    >
                        <circle cx="12" cy="12" r="9"></circle>
                        <path d="M12 7v5l3 3"></path>
                    </svg>
                    <div>
                        <p class="event-lbl">Time</p>
                        <p class="event-val">{event.time}</p>
                    </div>
                </div>
                <div class="event-row">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#157A78"
                        stroke-width="1.2"
                        stroke-linecap="round"
                    >
                        <path
                            d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z"
                        ></path>
                    </svg>
                    <div>
                        <p class="event-lbl">Venue</p>
                        <p class="event-val">{event.venue}</p>
                    </div>
                </div>
                <div class="event-row">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#157A78"
                        stroke-width="1.2"
                        stroke-linecap="round"
                    >
                        <path d="M3 6l4-4 5 4 5-4 4 4-2 14H5L3 6z"></path>
                    </svg>
                    <div>
                        <p class="event-lbl">Dress</p>
                        <p class="event-val">{event.dress}</p>
                    </div>
                </div>
            </div>

            {event.address && <p class="event-address">{event.address}</p>}

            <div class="btn-row">
                {
                    calData.startDatetime && (
                        <button id="cal-btn" class="btn-ghost" type="button">
                            <svg
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                            >
                                <rect
                                    x="3"
                                    y="4"
                                    width="18"
                                    height="18"
                                    rx="2"
                                />
                                <path d="M16 2v4M8 2v4M3 10h18M12 14v4M10 16h4" />
                            </svg>
                            Add to calendar
                        </button>
                    )
                }
            </div>
        </div>

        <!-- Countdown card — live days/hours/minutes/seconds to start_datetime.
             Falls back to a placeholder message when no date is set yet. -->
        <div class="countdown-card" id="countdown-card">
            <p class="countdown-label">Counting down to</p>
            {
                calData.startDatetime ? (
                    <div class="countdown-grid" id="countdown-grid">
                        <div class="countdown-unit">
                            <p class="countdown-value" id="cd-days">00</p>
                            <p class="countdown-unit-label">Days</p>
                        </div>
                        <div class="countdown-unit">
                            <p class="countdown-value" id="cd-hours">00</p>
                            <p class="countdown-unit-label">Hours</p>
                        </div>
                        <div class="countdown-unit">
                            <p class="countdown-value" id="cd-mins">00</p>
                            <p class="countdown-unit-label">Minutes</p>
                        </div>
                        <div class="countdown-unit">
                            <p class="countdown-value" id="cd-secs">00</p>
                            <p class="countdown-unit-label">Seconds</p>
                        </div>
                    </div>
                ) : (
                    <div class="countdown-placeholder">
                        <svg
                            width="26"
                            height="26"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="#C9952C"
                            stroke-width="1.2"
                            stroke-linecap="round"
                        >
                            <circle cx="12" cy="12" r="9" />
                            <path d="M12 7v5l3 3" />
                        </svg>
                        <span>Date &amp; time coming soon</span>
                    </div>
                )
            }
        </div>

        <!-- Venue card — floats higher than the event-card via a stronger
             shadow. Two sections: venue photo (top) and map (bottom),
             separated by a hairline divider inside a single card. -->
        <div class="venue-card">
            <div class="venue-card-image">
                {
                    venueImageSrc ? (
                        <img
                            src={venueImageSrc}
                            alt={event.venue}
                            loading="lazy"
                        />
                    ) : (
                        <div class="venue-card-placeholder">
                            <svg
                                width="32"
                                height="32"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="#C4622D"
                                stroke-width="1"
                                stroke-linecap="round"
                            >
                                <path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6" />
                            </svg>
                            <span>Venue photo here</span>
                        </div>
                    )
                }
            </div>

            <div class="venue-card-divider"></div>

            <div class="venue-card-map">
                {
                    event.maps_url ? (
                        <iframe
                            src={event.maps_url}
                            width="100%"
                            height="100%"
                            style="border:0;display:block;"
                            loading="lazy"
                        />
                    ) : (
                        <div class="venue-card-map-placeholder">
                            <svg
                                width="28"
                                height="28"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="#157A78"
                                stroke-width="1.2"
                                stroke-linecap="round"
                            >
                                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z" />
                            </svg>
                            <span>Map &amp; directions coming soon</span>
                        </div>
                    )
                }
            </div>
        </div>
    </div>

    <script
        id="cal-data"
        type="application/json"
        is:inline
        set:html={JSON.stringify(calData)}
    />
    <script>
        const raw = document.getElementById("cal-data")?.textContent ?? "{}";
        const { startDatetime, endDatetime, venue, address, mapsUrl } =
            JSON.parse(raw);

        if (startDatetime) {
            const toICSDate = (iso: string) =>
                iso.replace(/[-:]/g, "").replace(/\+\d{2}:\d{2}$/, "+0530");

            document
                .getElementById("cal-btn")
                ?.addEventListener("click", () => {
                    const ics = [
                        "BEGIN:VCALENDAR",
                        "VERSION:2.0",
                        "BEGIN:VEVENT",
                        `DTSTART;TZID=Asia/Kolkata:${toICSDate(startDatetime)}`,
                        endDatetime
                            ? `DTEND;TZID=Asia/Kolkata:${toICSDate(endDatetime)}`
                            : "",
                        "SUMMARY:Sankar & Priya — Reception & Celebration",
                        "DESCRIPTION:Some love stories begin with a flight.",
                        `LOCATION:${venue}${address ? ", " + address : ""}${mapsUrl ? " " + mapsUrl : ""}`,
                        mapsUrl
                            ? `X-APPLE-STRUCTURED-LOCATION;VALUE=URI;X-ADDRESS=${address};X-TITLE=${venue}:${mapsUrl}`
                            : "",
                        "END:VEVENT",
                        "END:VCALENDAR",
                    ]
                        .filter(Boolean)
                        .join("\r\n");

                    const blob = new Blob([ics], { type: "text/calendar" });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement("a");
                    a.href = url;
                    a.download = "sankar-priya.ics";
                    a.click();
                    URL.revokeObjectURL(url);
                });
        }

        if (startDatetime) {
            const target = new Date(startDatetime).getTime();
            const pad = (n: number) => String(n).padStart(2, "0");
            const daysEl = document.getElementById("cd-days");
            const hoursEl = document.getElementById("cd-hours");
            const minsEl = document.getElementById("cd-mins");
            const secsEl = document.getElementById("cd-secs");
            const grid = document.getElementById("countdown-grid");
            let timer: ReturnType<typeof setInterval>;

            const tick = () => {
                const diff = target - Date.now();

                if (diff <= 0) {
                    if (grid) {
                        grid.innerHTML =
                            '<p class="countdown-arrived">The celebration has begun!</p>';
                    }
                    clearInterval(timer);
                    return;
                }

                const totalSeconds = Math.floor(diff / 1000);
                const days = Math.floor(totalSeconds / 86400);
                const hours = Math.floor((totalSeconds % 86400) / 3600);
                const mins = Math.floor((totalSeconds % 3600) / 60);
                const secs = totalSeconds % 60;

                if (daysEl) daysEl.textContent = pad(days);
                if (hoursEl) hoursEl.textContent = pad(hours);
                if (minsEl) minsEl.textContent = pad(mins);
                if (secsEl) secsEl.textContent = pad(secs);
            };

            tick();
            timer = setInterval(tick, 1000);
        }
    </script>
</section>
