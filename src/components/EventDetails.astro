---
interface Props {
    event: {
        date: string;
        time: string;
        venue: string;
        address: string;
        maps_url?: string;
        dress: string;
    };
}
const { event } = Astro.props;
---

<section id="event">
    <div class="inner">
        <span class="eyebrow">The event</span>
        <h2 class="sec-heading">Reception &amp;</h2>
        <span class="sec-script">Celebration</span>

        <div class="event-list">
            <div class="event-row">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#146B72"
                    stroke-width="1.2"
                    stroke-linecap="round"
                    ><rect x="3" y="4" width="18" height="18" rx="2"
                    ></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg
                >
                <div>
                    <p class="event-lbl">Date</p><p class="event-val">
                        {event.date}
                    </p>
                </div>
            </div>
            <div class="event-row">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#146B72"
                    stroke-width="1.2"
                    stroke-linecap="round"
                    ><circle cx="12" cy="12" r="9"></circle><path
                        d="M12 7v5l3 3"></path></svg
                >
                <div>
                    <p class="event-lbl">Time</p><p class="event-val">
                        {event.time}
                    </p>
                </div>
            </div>
            <div class="event-row">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#146B72"
                    stroke-width="1.2"
                    stroke-linecap="round"
                    ><path
                        d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z"
                    ></path></svg
                >
                <div>
                    <p class="event-lbl">Venue</p><p class="event-val">
                        {event.venue}
                    </p>
                </div>
            </div>
            <div class="event-row">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="#146B72"
                    stroke-width="1.2"
                    stroke-linecap="round"
                    ><path d="M3 6l4-4 5 4 5-4 4 4-2 14H5L3 6z"></path></svg
                >
                <div>
                    <p class="event-lbl">Dress</p><p class="event-val">
                        {event.dress}
                    </p>
                </div>
            </div>
        </div>

        {
            event.address && (
                <p style="font-family:'Jost',sans-serif;font-size:13px;color:#7A6A5E;margin-top:16px;line-height:1.6;">
                    {event.address}
                </p>
            )
        }

        <div class="map-placeholder">
            {
                event.maps_url ? (
                    <iframe
                        src={event.maps_url}
                        width="100%"
                        height="100%"
                        style="border:0"
                        loading="lazy"
                    />
                ) : (
                    "Map · Directions"
                )
            }
        </div>
    </div>
</section>
