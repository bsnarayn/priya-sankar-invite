---
interface Props {
    event: {
        date: string;
        time: string;
        venue: string;
        address: string;
        maps_url?: string;
        dress: string;
        venue_image?: string;
        start_datetime?: string | null;
        end_datetime?: string | null;
    };
}
const { event } = Astro.props;

const venueImageSrc = event.venue_image
    ? `/images/venue/${event.venue_image}`
    : undefined;

// Pass datetime data to the client via a JSON island
const calData = {
    startDatetime: event.start_datetime ?? null,
    endDatetime: event.end_datetime ?? null,
    venue: event.venue,
    address: event.address,
    mapsUrl: event.maps_url,
};
---

<section id="event">
    <div class="inner">
        <h2 class="sec-heading">Reception &amp;</h2>
        <span class="sec-script">Celebration</span>

        <div class="event-card">
            <div class="event-list">
                <div class="event-row">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#146B72"
                        stroke-width="1.2"
                        stroke-linecap="round"
                        ><rect x="3" y="4" width="18" height="18" rx="2"
                        ></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg
                    >
                    <div>
                        <p class="event-lbl">Date</p><p class="event-val">
                            {event.date}
                        </p>
                    </div>
                </div>
                <div class="event-row">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#146B72"
                        stroke-width="1.2"
                        stroke-linecap="round"
                        ><circle cx="12" cy="12" r="9"></circle><path
                            d="M12 7v5l3 3"></path></svg
                    >
                    <div>
                        <p class="event-lbl">Time</p><p class="event-val">
                            {event.time}
                        </p>
                    </div>
                </div>
                <div class="event-row">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#146B72"
                        stroke-width="1.2"
                        stroke-linecap="round"
                        ><path
                            d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z"
                        ></path></svg
                    >
                    <div>
                        <p class="event-lbl">Venue</p><p class="event-val">
                            {event.venue}
                        </p>
                    </div>
                </div>
                <div class="event-row">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#146B72"
                        stroke-width="1.2"
                        stroke-linecap="round"
                        ><path d="M3 6l4-4 5 4 5-4 4 4-2 14H5L3 6z"></path></svg
                    >
                    <div>
                        <p class="event-lbl">Dress</p><p class="event-val">
                            {event.dress}
                        </p>
                    </div>
                </div>
            </div>

            {event.address && <p class="event-address">{event.address}</p>}

            <div class="btn-row">
                {
                    calData.startDatetime && (
                        <button id="cal-btn" class="btn-ghost" type="button">
                            <svg
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                            >
                                <rect
                                    x="3"
                                    y="4"
                                    width="18"
                                    height="18"
                                    rx="2"
                                />
                                <path d="M16 2v4M8 2v4M3 10h18M12 14v4M10 16h4" />
                            </svg>
                            Add to calendar
                        </button>
                    )
                }
            </div>
        </div>

        {
            venueImageSrc ? (
                <div class="venue-image">
                    <img src={venueImageSrc} alt={event.venue} loading="lazy" />
                </div>
            ) : (
                <div class="venue-image venue-image--placeholder">
                    <svg
                        width="32"
                        height="32"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#C4622D"
                        stroke-width="1"
                        stroke-linecap="round"
                    >
                        <path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6" />
                    </svg>
                    <span>Venue photo here</span>
                </div>
            )
        }

        <div class="map-placeholder">
            {
                event.maps_url ? (
                    <iframe
                        src={event.maps_url}
                        width="100%"
                        height="100%"
                        style="border:0"
                        loading="lazy"
                    />
                ) : (
                    <div class="map-placeholder-content">
                        <svg
                            width="28"
                            height="28"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="#146B72"
                            stroke-width="1.2"
                            stroke-linecap="round"
                        >
                            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z" />
                        </svg>
                        <span>Map &amp; directions coming soon</span>
                    </div>
                )
            }
        </div>
    </div>

    <script
        id="cal-data"
        type="application/json"
        is:inline
        set:html={JSON.stringify(calData)}
    />
    <script>
        const raw = document.getElementById("cal-data")?.textContent ?? "{}";
        const { startDatetime, endDatetime, venue, address, mapsUrl } =
            JSON.parse(raw);

        if (startDatetime) {
            const toICSDate = (iso: string) =>
                iso.replace(/[-:]/g, "").replace(/\+\d{2}:\d{2}$/, "+0530");

            document
                .getElementById("cal-btn")
                ?.addEventListener("click", () => {
                    const ics = [
                        "BEGIN:VCALENDAR",
                        "VERSION:2.0",
                        "BEGIN:VEVENT",
                        `DTSTART;TZID=Asia/Kolkata:${toICSDate(startDatetime)}`,
                        endDatetime
                            ? `DTEND;TZID=Asia/Kolkata:${toICSDate(endDatetime)}`
                            : "",
                        "SUMMARY:Sankar & Priya — Reception & Celebration",
                        "DESCRIPTION:Some love stories begin with a flight.",
                        `LOCATION:${venue}${address ? ", " + address : ""}${mapsUrl ? " " + mapsUrl : ""}`,
                        mapsUrl
                            ? `X-APPLE-STRUCTURED-LOCATION;VALUE=URI:${mapsUrl}`
                            : "",
                        "END:VEVENT",
                        "END:VCALENDAR",
                    ]
                        .filter(Boolean)
                        .join("\r\n");

                    const blob = new Blob([ics], { type: "text/calendar" });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement("a");
                    a.href = url;
                    a.download = "sankar-priya.ics";
                    a.click();
                    URL.revokeObjectURL(url);
                });
        }
    </script>
</section>
