---
// Balloons — joyful rising balloons, bottom to top
// Self-contained: renders its own full-viewport layer and starts
// animating on load. Call (window as any).__stopBalloons() to fade out
// and halt.
---

<div
    id="balloon-layer"
    style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:52;pointer-events:none;"
    aria-hidden="true"
>
</div>

<script>
    import { gsap } from "gsap";

    const balloonLayer = document.getElementById("balloon-layer");

    // Soft, palette-adjacent balloon tones
    const BALLOON_COLORS = ["#E8A0A8", "#C9A227", "#9FC9C9", "#FDF6EE"];
    const BALLOON_COUNT = 5;

    let balloonTweens: gsap.core.Tween[] = [];
    let layerFadeTween: gsap.core.Tween | null = null;

    function balloonSVG(color: string, width: number) {
        const height = width * 1.2;
        const stringHeight = width * 1.8;
        const totalHeight = height + stringHeight;
        const cx = width / 2;
        const highlightR = width * 0.16;

        return `<svg width="${width}" height="${totalHeight}" viewBox="0 0 ${width} ${totalHeight}" xmlns="http://www.w3.org/2000/svg" style="display:block;">
            <ellipse cx="${cx}" cy="${height / 2}" rx="${width / 2}" ry="${height / 2}" fill="${color}" />
            <ellipse cx="${cx - width * 0.15}" cy="${height * 0.28}" rx="${highlightR}" ry="${highlightR * 1.3}" fill="#FFFFFF" opacity="0.35" />
            <path d="M${cx - width * 0.06} ${height} L${cx + width * 0.06} ${height} L${cx} ${height + width * 0.12} Z" fill="${color}" />
            <line x1="${cx}" y1="${height + width * 0.12}" x2="${cx}" y2="${totalHeight}" stroke="${color}" stroke-width="1" opacity="0.5" />
        </svg>`;
    }

    function spawnBalloons() {
        if (!balloonLayer) return;
        balloonLayer.innerHTML = "";
        balloonTweens = [];

        const vw = window.innerWidth;
        const vh = window.innerHeight;

        for (let i = 0; i < BALLOON_COUNT; i++) {
            const width = 36 + Math.random() * 28; // 36–64px
            const color =
                BALLOON_COLORS[
                    Math.floor(Math.random() * BALLOON_COLORS.length)
                ];
            const opacity = 0.55 + Math.random() * 0.3; // 0.55–0.85

            const riseDuration = 18 + Math.random() * 12; // 18–30s — slow rise
            const sway = 15 + Math.random() * 25; // 15–40px
            const swayDuration = 5 + Math.random() * 3; // 5–8s
            const rotateAmount = 4 + Math.random() * 6; // 4–10° — gentle tilt sway
            const rotateDir = Math.random() > 0.5 ? 1 : -1;

            const el = document.createElement("div");
            el.style.position = "absolute";
            el.style.top = "0";
            el.style.opacity = String(opacity);
            el.innerHTML = balloonSVG(color, width);
            balloonLayer.appendChild(el);

            const totalHeight = width * 1.2 + width * 1.8;

            // Base horizontal position (CSS `left`) — only changed on a
            // rise-cycle repeat. Sway uses `x` (transform) separately,
            // so the two never collide.
            function setBaseX() {
                el.style.left = `${Math.random() * (vw - width)}px`;
            }
            setBaseX();

            gsap.set(el, { y: vh + totalHeight, x: 0, rotation: 0 });

            const riseTween = gsap.to(el, {
                y: -totalHeight,
                duration: riseDuration,
                repeat: -1,
                ease: "none",
                onRepeat: () => {
                    setBaseX();
                    gsap.set(el, { y: vh + totalHeight });
                },
            });
            riseTween.progress(Math.random());

            const swayTween = gsap.to(el, {
                x: `+=${sway}`,
                duration: swayDuration,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            swayTween.progress(Math.random());

            // Gentle tilt — like a balloon bobbing as it rises
            const rotateTween = gsap.to(el, {
                rotation: rotateAmount * rotateDir,
                duration: swayDuration * 0.9,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            rotateTween.progress(Math.random());

            balloonTweens.push(riseTween, swayTween, rotateTween);
        }
    }

    // Spawn (if not already present) and ensure the layer is visible.
    function startBalloons() {
        if (!balloonLayer) return;
        if (layerFadeTween) layerFadeTween.kill();

        if (balloonLayer.children.length === 0) {
            spawnBalloons();
        }

        layerFadeTween = gsap.to(balloonLayer, {
            opacity: 1,
            duration: 0.6,
            ease: "power1.out",
        });
    }

    // Fade the layer out, then stop tweens and clear once invisible.
    function stopBalloons() {
        if (!balloonLayer) return;
        if (layerFadeTween) layerFadeTween.kill();

        layerFadeTween = gsap.to(balloonLayer, {
            opacity: 0,
            duration: 0.6,
            ease: "power1.in",
            onComplete: () => {
                balloonTweens.forEach((t) => t.kill());
                balloonLayer!.innerHTML = "";
                balloonTweens = [];
            },
        });
    }

    (window as any).__startBalloons = startBalloons;
    (window as any).__stopBalloons = stopBalloons;

    spawnBalloons();
</script>
